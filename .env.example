# GUADRAILS RAG WITH ENDEE Configuration
# ============================================================
# Copy this file to .env and update values as needed.
# This project runs 100% offline with no cloud API keys required.
#
#   cp .env.example .env

# ── Ollama Configuration ──────────────────────────────────
# URL where Ollama server is running
# Default: http://localhost:11434
# Docker users: http://host.docker.internal:11434
OLLAMA_HOST=http://localhost:11434

# Ollama model to use for inference
# Options: gemma2:2b, llama2, mistral, neural-chat, etc.
# Download models with: ollama pull <model-name>
OLLAMA_MODEL=gemma2:2b

# ── Endee Vector Database Configuration ───────────────────
# URL where Endee server is running
# Start Endee with: ./run.sh (from Endee repository)
ENDEE_HOST=http://localhost:8080

# Index name for storing embeddings
ENDEE_INDEX_NAME=guardrag_index

# Vector dimension (must match embeddings model)
# Default: 384 (for sentence-transformers/all-MiniLM-L6-v2)
ENDEE_VECTOR_DIM=384

# Similarity metric for vector search
# Options: cosine, l2, dot
ENDEE_METRIC=cosine

# ── FastAPI / Uvicorn Server Configuration ────────────────
# Server host to bind to
# 127.0.0.1 = localhost only
# 0.0.0.0 = all interfaces (use for Docker/remote access)
HOST=127.0.0.1

# Server port
# Note: PaaS platforms automatically set this via environment
PORT=8000

# ── Proxy Configuration (Optional) ──────────────────────
# Bypass proxy for HuggingFace and localhost (automatically set)
# Uncomment only if you need custom proxy settings
# NO_PROXY=huggingface.co,*.huggingface.co,localhost,127.0.0.1
# no_proxy=huggingface.co,*.huggingface.co,localhost,127.0.0.1

# ── Logging Configuration ─────────────────────────────────
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ── Document Processing Configuration ─────────────────────
# Chunk size for document splitting (tokens)
CHUNK_SIZE=1000

# Chunk overlap for context preservation
CHUNK_OVERLAP=200

# ── Safety & Guardrails Configuration ──────────────────────
# Sensitivity level: Public, Internal, Confidential, Restricted
SENSITIVITY_LEVEL=Internal

# Enable safety checks
ENABLE_GUARDRAILS=true

# ── Optional: Development Settings ──────────────────────────
# Enable uvicorn auto-reload on file changes (dev only)
# RELOAD=false

# Debug mode (extra logging)
# DEBUG=false

# ── HuggingFace (optional) ───────────────────────────────────────────────────
# Only needed if you hit rate limits downloading the embedding model on first run.
# HUGGINGFACE_TOKEN=hf_...
